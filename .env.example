# ─── Database ───────────────────────────────────────────────
# Dev default: SQLite (zero external deps, runnable anywhere).
# Production target (per APP_BLUEPRINT): PostgreSQL — set provider to
# "postgresql" in prisma/schema.prisma and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"

# ─── Auth (NextAuth) ────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-only-change-me-in-production-please-32+chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe (subscription billing — optional in dev) ────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_ENTERPRISE=""

# ─── Encryption (field-level, AES-256-GCM) ──────────────────
# base64-encoded 32 bytes (openssl rand -base64 32). If unset, a key is derived
# from NEXTAUTH_SECRET (fine for dev; set explicitly in production).
ENCRYPTION_KEY=""

# ─── Email (Resend — optional; dev logs the link if unset) ──
# Set RESEND_API_KEY in production to actually send verification/invite emails.
RESEND_API_KEY=""
# Default "from" address; per-agency display name is applied automatically.
MAIL_FROM="Cura_Sera <onboarding@resend.dev>"

# ─── White-label multi-tenant ───────────────────────────────
# Root domain for platform subdomains (<slug>.PLATFORM_ROOT_DOMAIN → agency).
# Leave blank in dev — *.localhost subdomains resolve automatically.
PLATFORM_ROOT_DOMAIN=""

# ─── App ────────────────────────────────────────────────────
APP_NAME="Cura_Sera"
